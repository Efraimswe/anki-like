generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Deck {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String    @db.VarChar(255)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime  @default(now()) @map("updated_at") @db.Timestamptz()
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz()

  cards Card[]

  @@map("decks")
}

model Card {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deckId       String    @map("deck_id") @db.Uuid
  front        String    @db.Text
  back         String    @db.Text
  type         String    @db.VarChar(10)
  tags         String[]  @default([])
  sourceCardId String?   @map("source_card_id") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime  @default(now()) @map("updated_at") @db.Timestamptz()
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz()

  deck       Deck       @relation(fields: [deckId], references: [id])
  sourceCard Card?      @relation("ReverseCards", fields: [sourceCardId], references: [id])
  reverseOf  Card[]     @relation("ReverseCards")
  cardState  CardState?
  reviewLogs ReviewLog[]

  @@index([deckId], map: "idx_cards_deck_id")
  @@index([tags], type: Gin, map: "idx_cards_tags")
  @@map("cards")
}

model CardState {
  cardId      String   @id @map("card_id") @db.Uuid
  phase       String   @default("new") @db.VarChar(12)
  interval    Int      @default(0)
  easeFactor  Float    @default(2.5) @map("ease_factor") @db.Real
  repetitions Int      @default(0)
  dueDate     DateTime @default(now()) @map("due_date") @db.Timestamptz()
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz()

  card Card @relation(fields: [cardId], references: [id])

  @@index([dueDate], map: "idx_card_states_due_date")
  @@map("card_states")
}

model ReviewLog {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cardId         String   @map("card_id") @db.Uuid
  rating         Int      @db.SmallInt
  intervalBefore Int      @map("interval_before")
  intervalAfter  Int      @map("interval_after")
  easeBefore     Float    @map("ease_before") @db.Real
  easeAfter      Float    @map("ease_after") @db.Real
  timeTakenMs    Int?     @map("time_taken_ms")
  reviewedAt     DateTime @default(now()) @map("reviewed_at") @db.Timestamptz()

  card Card @relation(fields: [cardId], references: [id])

  @@index([cardId], map: "idx_review_logs_card_id")
  @@index([reviewedAt], map: "idx_review_logs_reviewed_at")
  @@map("review_logs")
}

model DailyLimit {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  maxNewCards Int      @default(20) @map("max_new_cards")
  maxReviews  Int      @default(200) @map("max_reviews")
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz()

  @@map("daily_limits")
}

model DailyCounter {
  date        DateTime @id @default(dbgenerated("CURRENT_DATE")) @db.Date
  newCount    Int      @default(0) @map("new_count")
  reviewCount Int      @default(0) @map("review_count")

  @@map("daily_counters")
}
