generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id
  email          String   @unique @db.VarChar(255)
  displayName    String?  @map("display_name") @db.VarChar(100)
  targetLanguage String   @default("ru") @map("target_language") @db.VarChar(10)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  decks Deck[]
  skillProgress SkillProgress[]
  planGoals PlanGoal[]

  @@map("users")
}

model Deck {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String    @map("user_id")
  name             String    @db.VarChar(255)
  dailyReviewLimit Int       @default(20) @map("daily_review_limit")
  dailyAddLimit    Int       @default(20) @map("daily_add_limit")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz()

  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards    Card[]
  counters DeckDailyCounter[]

  @@index([userId], map: "idx_decks_user_id")
  @@map("decks")
}

model Card {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deckId    String    @map("deck_id") @db.Uuid
  word      String    @db.Text
  translate String    @db.Text
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz()

  deck       Deck        @relation(fields: [deckId], references: [id])
  cardState  CardState?
  reviewLogs ReviewLog[]

  @@index([deckId], map: "idx_cards_deck_id")
  @@map("cards")
}

model CardState {
  cardId        String    @id @map("card_id") @db.Uuid
  phase         String    @default("new") @db.VarChar(12)
  interval      Int       @default(0)
  easeFactor    Float     @default(2.5) @map("ease_factor") @db.Real
  repetitions   Int       @default(0)
  learningStep  Int       @default(0) @map("learning_step")
  stability     Float     @default(0) @db.Real
  difficulty    Float     @default(0) @db.Real
  scheduledDays Int       @default(0) @map("scheduled_days")
  reps          Int       @default(0)
  lapses        Int       @default(0)
  dueDate       DateTime  @default(now()) @map("due_date") @db.Timestamptz()
  lastReview    DateTime? @map("last_review") @db.Timestamptz()
  updatedAt     DateTime  @default(now()) @map("updated_at") @db.Timestamptz()

  card Card @relation(fields: [cardId], references: [id])

  @@index([dueDate], map: "idx_card_states_due_date")
  @@map("card_states")
}

model ReviewLog {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cardId         String   @map("card_id") @db.Uuid
  rating         Int      @db.SmallInt
  intervalBefore Int      @map("interval_before")
  intervalAfter  Int      @map("interval_after")
  easeBefore     Float    @map("ease_before") @db.Real
  easeAfter      Float    @map("ease_after") @db.Real
  timeTakenMs    Int?     @map("time_taken_ms")
  reviewedAt     DateTime @default(now()) @map("reviewed_at") @db.Timestamptz()

  card Card @relation(fields: [cardId], references: [id])

  @@index([cardId], map: "idx_review_logs_card_id")
  @@index([reviewedAt], map: "idx_review_logs_reviewed_at")
  @@map("review_logs")
}

model SkillProgress {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String   @map("user_id")
  skill          String   @db.VarChar(20)
  completedLevel Int      @default(0) @map("completed_level")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, skill], map: "idx_skill_progress_user_skill")
  @@map("skill_progress")
}

model PlanGoal {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id")
  skill       String   @db.VarChar(20)
  level       Int
  title       String   @db.VarChar(200)
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediumGoals PlanMediumGoal[]

  @@index([userId], map: "idx_plan_goals_user_id")
  @@map("plan_goals")
}

model PlanMediumGoal {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bigGoalId String   @map("big_goal_id") @db.Uuid
  title     String   @db.VarChar(200)
  completed Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  bigGoal   PlanGoal @relation(fields: [bigGoalId], references: [id], onDelete: Cascade)

  @@index([bigGoalId], map: "idx_plan_medium_goals_big_goal_id")
  @@map("plan_medium_goals")
}

model DeckDailyCounter {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deckId      String   @map("deck_id") @db.Uuid
  date        DateTime @default(dbgenerated("CURRENT_DATE")) @db.Date
  reviewCount Int      @default(0) @map("review_count")

  deck Deck @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@unique([deckId, date], map: "idx_deck_daily_counters_deck_date")
  @@map("deck_daily_counters")
}
