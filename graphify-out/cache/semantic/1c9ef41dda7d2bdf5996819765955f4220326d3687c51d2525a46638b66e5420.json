{"nodes": [{"id": "specs_001_nestjs_backend_research_fastify_adapter", "label": "Decision R1: NestJS with Fastify Adapter", "file_type": "rationale", "source_file": "specs/001-nestjs-backend/research.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Fastify is ~2x faster than Express for JSON serialization; the high-frequency review endpoint benefits from schema-based serialization. Express rejected as slower; Hono/Elysia rejected for lacking NestJS integration."}, {"id": "specs_001_nestjs_backend_research_raw_sql_pg", "label": "Decision R2: Raw SQL with node-postgres (pg)", "file_type": "rationale", "source_file": "specs/001-nestjs-backend/research.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "User requirement; raw SQL gives full control over query optimization for the due-cards date-filter query; Neon works natively with pg over SSL. TypeORM, Prisma, and Drizzle explicitly rejected. Migrations via numbered .sql files tracked in schema_migrations."}, {"id": "specs_001_nestjs_backend_research_sm2_implementation", "label": "Decision R3: SM-2 Algorithm Implementation", "file_type": "rationale", "source_file": "specs/001-nestjs-backend/research.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Classic SM-2: well-documented, deterministic, testable; constitution mandates it. EF' = EF + (0.1 - (5-q)*(0.08 + (5-q)*0.02)); default EF 2.5, min 1.3, max interval 365d; q<3 resets reps and interval=1; reps 0 -> 1d, reps 1 -> 6d, else interval*EF. FSRS rejected as too complex for v1 per Simplicity principle."}, {"id": "specs_001_nestjs_backend_research_neon_serverless", "label": "Decision R4: Neon Serverless PostgreSQL", "file_type": "rationale", "source_file": "specs/001-nestjs-backend/research.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "User-provided infrastructure; standard PostgreSQL wire protocol works with pg over SSL; pooler endpoint in URL; keep pool max ~10 connections for serverless."}, {"id": "specs_001_nestjs_backend_research_reverse_card_strategy", "label": "Decision R5: Reverse Card Strategy", "file_type": "rationale", "source_file": "specs/001-nestjs-backend/research.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Auto-generate two separate Card rows (original and swapped front/back), both type 'basic' after creation, linked via sourceCardId, each with its own CardState \u2014 matches Anki and requires no special-casing in review logic."}, {"id": "specs_001_nestjs_backend_research_lifecycle_transitions", "label": "Decision R6: Card Lifecycle Phase Transitions", "file_type": "rationale", "source_file": "specs/001-nestjs-backend/research.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Graduation from Learning (and Relearning back to Review) requires one Good/Easy rating \u2014 simplest model matching Anki defaults; kept non-configurable per Simplicity principle, can be made configurable later."}, {"id": "specs_001_nestjs_backend_research_statistics_time_range", "label": "Decision R7: Statistics Time Range", "file_type": "rationale", "source_file": "specs/001-nestjs-backend/research.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "All-time by default with optional date-range filter \u2014 most useful default without overcomplicating the API."}], "edges": [{"source": "specs_001_nestjs_backend_research_fastify_adapter", "target": "specs_001_nestjs_backend_plan_implementation_plan", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "specs/001-nestjs-backend/research.md", "sou