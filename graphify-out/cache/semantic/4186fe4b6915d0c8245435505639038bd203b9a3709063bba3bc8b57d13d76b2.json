{"nodes": [{"id": "specs_009_custom_llm_toolcall_research_sse_streaming_openai_compatible", "label": "OpenAI-Compatible SSE Streaming with Tools", "file_type": "rationale", "source_file": "specs/009-custom-llm-toolcall/research.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "SSE with stream: true against /v1/chat/completions; tool calls arrive as delta.tool_calls JSON string fragments that must be concatenated across chunks; finish_reason 'tool_calls' vs 'stop' distinguishes tool invocation from normal completion."}, {"id": "specs_009_custom_llm_toolcall_research_server_side_tool_call_loop", "label": "Server-Side Tool-Call Loop", "file_type": "rationale", "source_file": "specs/009-custom-llm-toolcall/research.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The loop runs entirely server-side within a single route handler request: detect tool_calls, execute the tool (DB write), append assistant + tool messages, call the LLM again until finish_reason 'stop'. Keeps the client a simple stream reader and avoids extra HTTP round trips; client-side loop rejected because it would expose LLM_API_KEY."}, {"id": "specs_009_custom_llm_toolcall_research_plain_text_streaming", "label": "Plain-Text ReadableStream Response to Client", "file_type": "rationale", "source_file": "specs/009-custom-llm-toolcall/research.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Route handlers return a Response with a ReadableStream body and Content-Type text/plain \u2014 no SSE framing needed since only one event type (text tokens) is sent; EventSource rejected because it does not support POST."}, {"id": "specs_009_custom_llm_toolcall_research_usellmchat_hook", "label": "useLLMChat Custom Hook", "file_type": "concept", "source_file": "specs/009-custom-llm-toolcall/research.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Custom useState + fetch hook replacing useChat from @ai-sdk/react: manages messages, status (ready/streaming/error), and sendMessage which reads the response body ReadableStream and appends tokens to the last assistant message."}, {"id": "specs_009_custom_llm_toolcall_research_json_schema_tool_definitions", "label": "Plain JSON Schema Tool Definitions (No Zod)", "file_type": "rationale", "source_file": "specs/009-custom-llm-toolcall/research.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Tools defined as plain TypeScript objects matching the OpenAI tools array schema, using JSON Schema directly instead of Zod, since the full pipeline is controlled in-house."}], "edges": [{"source": "specs_009_custom_llm_toolcall_research_server_side_tool_call_loop", "target": "specs_009_custom_llm_toolcall_data_model_chatmessage", "relation": "shares_data_with", "confidence": "INFERRED", "confidence_score": 0.95, "source_file": "specs/009-custom-llm-toolcall/research.md", "source_location": null, "weight": 1.0}, {"source": "specs_009_custom_llm_toolcall_research_json_schema_tool_definitions", "target": "specs_009_custom_llm_toolcall_data_model_tooldefinition", "relation": "rationale_for", "confidence": "INFERRED", "confidence_score": 0.95, "source_file": "specs/009-custom-llm-toolcall/research.md", "source_location": null, "weight": 1.0}, {"source": "specs_009_custom_llm_toolcall_research_plain_text_streaming", "target": "specs_009_custom_llm_toolcall_contracts_chat_api_chat_api_contract", "relation": "rationale_for", "confidence": "INFERRED", "confidence_score": 0.95, "source_file": "specs/009-custom-llm-toolcall/research.md", "source_location": null, "weight": 1.0}, {"source": "specs_009_custom_llm_toolcall_research_usellmchat_hook", "target": "specs_009_custom_llm_toolcall_data_model_clientchatmessage", "relation": "shares_data_with", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "specs/009-custom-llm-toolcall/research.md", "source_location": null, "weight": 1.0}, {"source": "specs_009_custom_llm_toolcall_research_usellmchat_hook", "target": "specs_008_onboarding_flow_research_usechat_hook_pattern", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "specs/009-custom-llm-toolcall/research.md", "source_location": null, "weight": 1.0}, {"source": "specs_009_custom_llm_toolcall_research_usellmchat_hook", "target": "specs_008_onboarding_flow_research_usechat_hook_pattern", "relation": "semantically_similar_to", "confidence": "INFERRED", "confidence_score": 0.9, "source_file": "specs/009-custom-llm-toolcall/research.md", "source_location": null, "weight": 1.0}, {"source": "specs_009_custom_llm_toolcall_research_sse_streaming_openai_compatible", "target": "specs_008_onboarding_flow_research_streaming_chat_route_pattern", "relation": "semantically_similar_to", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "specs/009-custom-llm-toolcall/research.md", "source_location": null, "weight": 1.0}], "hyperedges": [{"id": "custom_llm_engine_stack", "label": "Custom LLM Engine Stack", "nodes": ["specs_009_custom_llm_toolcall_tasks_llm_client_module", "specs_009_custom_llm_toolcall_research_sse_streaming_openai_compatible", "specs_009_custom_llm_toolcall_research_server_side_tool_call_loop", "specs_009_custom_llm_toolcall_research_plain_text_streaming", "specs_009_custom_llm_toolcall_research_usellmchat_hook"], "relation": "form", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "specs/009-custom-llm-toolcall/research.md"}]}