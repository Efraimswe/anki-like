{"nodes": [{"id": "specs_004_anki_learning_steps_research_document", "label": "Research: Anki-Like Learning Steps", "file_type": "document", "source_file": "specs/004-anki-learning-steps/research.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_004_anki_learning_steps_research_minute_based_intervals", "label": "Minute-Based Interval Storage", "file_type": "rationale", "source_file": "specs/004-anki-learning-steps/research.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Store intervals as integer minutes (1440 = 1 day): sub-day precision without schema type change; existing values migrated via interval * 1440. Rejected separate intervalMinutes field (splits logic) and float days (floating point imprecision causes scheduling bugs)."}, {"id": "specs_004_anki_learning_steps_research_server_side_interval_hints", "label": "Server-Side Interval Hint Calculation", "file_type": "rationale", "source_file": "specs/004-anki-learning-steps/research.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Hints computed in SM-2 service and returned in the due-cards response, keeping algorithm logic in one place. Rejected client-side calc (duplicates SM-2 logic) and per-card endpoint (N+1 requests)."}, {"id": "specs_004_anki_learning_steps_research_graduating_interval", "label": "Graduating Interval Defaults", "file_type": "rationale", "source_file": "specs/004-anki-learning-steps/research.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Graduating interval 1 day (1440 min), Easy graduating interval 4 days (5760 min) \u2014 Anki's proven defaults matching user expectations."}], "edges": [{"source": "specs_004_anki_learning_steps_research_minute_based_intervals", "target": "specs_004_anki_learning_ste