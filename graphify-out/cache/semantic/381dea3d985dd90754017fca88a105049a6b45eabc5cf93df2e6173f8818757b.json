{"nodes": [{"id": "specs_004_anki_learning_steps_spec_document", "label": "Feature Specification: Anki-Like Learning Steps & Interval Hints", "file_type": "document", "source_file": "specs/004-anki-learning-steps/spec.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_004_anki_learning_steps_spec_learning_steps", "label": "Learning Steps", "file_type": "concept", "source_file": "specs/004-anki-learning-steps/spec.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Core bug fix: 'Again' previously set interval to 1 day so failed cards never reappeared in-session. Anki-style sub-day steps ([1, 10] minutes) let failed cards cycle back within the same study session, which is the fundamental behavior users expect from Anki-style tools."}, {"id": "specs_004_anki_learning_steps_spec_interval_hints", "label": "Interval Hints", "file_type": "concept", "source_file": "specs/004-anki-learning-steps/spec.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Users need to see the consequence of each rating choice (e.g. Again: 1m, Good: 10m, Easy: 4d) to make informed decisions; matches Anki UX."}], "edges": [{"source": "specs_004_anki_learning_steps_spec_document", "target": "specs_004_anki_learning_steps_spec_learning_steps", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "specs/004-anki-learning-steps/spec.md", "source_location": null, "weight": 1.0}, {"source": "specs_004_anki_learning_steps_spec_document", "target": "specs_004_anki_learning_steps_spec_interval_hints", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "specs/004-anki-learning-steps/spec.md", "source_location": null, "weight": 1.0}], "hyperedges": []}