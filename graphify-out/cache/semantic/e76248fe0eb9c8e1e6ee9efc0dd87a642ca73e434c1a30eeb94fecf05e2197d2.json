{"nodes": [{"id": "specs_006_nextjs_fullstack_migration_research_document", "label": "Research: Migrate to Next.js Fullstack App", "file_type": "document", "source_file": "specs/006-nextjs-fullstack-migration/research.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_006_nextjs_fullstack_migration_research_jose_jwt", "label": "jose JWT + Next.js Middleware Auth", "file_type": "rationale", "source_file": "specs/006-nextjs-fullstack-migration/research.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "jose chosen because it is Edge Runtime compatible (jsonwebtoken is not); root middleware.ts checks auth cookies and protects routes. next-auth rejected as unnecessary abstraction over existing custom JWT auth; Server-Actions-only rejected for losing REST compatibility."}, {"id": "specs_006_nextjs_fullstack_migration_research_route_handlers", "label": "Route Handlers Replace NestJS Controllers", "file_type": "rationale", "source_file": "specs/006-nextjs-fullstack-migration/research.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "app/api/*/route.ts gives a 1:1 mapping to existing REST endpoints, minimizing behavioral change. tRPC rejected (client changes, overkill); Server-Actions-only rejected (no GET/external consumers); mixed approach rejected for migration complexity."}, {"id": "specs_006_nextjs_fullstack_migration_research_zod_validation", "label": "Zod Request Validation", "file_type": "rationale", "source_file": "specs/006-nextjs-fullstack-migration/research.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Replaces NestJS class-validator DTOs: each DTO maps to a Zod schema with better TS inference and no decorator dependency. valibot rejected for weaker ecosystem."}, {"id": "specs_006_nextjs_fullstack_migration_research_prisma_singleton", "label": "Prisma Client Singleton Pattern", "file_type": "rationale", "source_file": "specs/006-nextjs-fullstack-migration/research.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Next.js dev hot-reload creates multiple Prisma instances, so the client is cached on globalThis in development. Schema moves from backend/prisma/ to root prisma/ unchanged; Drizzle/Accelerate rejected."}, {"id": "specs_006_nextjs_fullstack_migration_research_vitest_playwright", "label": "Vitest + Playwright Testing Strategy", "file_type": "rationale", "source_file": "specs/006-nextjs-fullstack-migration/research.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Vitest is Jest-API-compatible but faster with native ESM/TS, so SM-2 tests migrate with import-path changes only; Playwright covers full-stack e2e."}], "edges": [{"source": "specs_006_nextjs_fullstack_migration_research_jose_jwt", "target": "specs_006_nextjs_fullstack_migration_spec_nextjs_fullstack_migration", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "specs/006-nextjs-fullstack-migration/research.md", "source_location": null, "weight": 1.0}, {"source": "specs_006_nextjs_fullstack_migration_research_route_handlers", "target": "specs_006_nextjs_fullstack_migration_spec_nextjs_fullstack_migration", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "specs/006-nextjs-fullstack-migration/research.md", "source_location": null, "weight": 1.0}, {"source": "specs_006_nextjs_fullstack_migration_research_zod_validation", "target": "specs_006_nextjs_fullstack_migration_spec_nextjs_fullstack_migration", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "specs/006-nextjs-fullstack-migration/research.