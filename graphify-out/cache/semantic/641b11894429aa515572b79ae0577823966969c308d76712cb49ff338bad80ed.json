{"nodes": [{"id": "specs_005_jwt_auth_settings_research_document", "label": "Research: JWT Auth, Settings & Navigation", "file_type": "document", "source_file": "specs/005-jwt-auth-settings/research.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_005_jwt_auth_settings_research_httponly_cookie_tokens", "label": "HttpOnly Cookie Token Storage", "file_type": "rationale", "source_file": "specs/005-jwt-auth-settings/research.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "HttpOnly cookies are immune to XSS (localStorage rejected for XSS risk). Access token 15min SameSite=Strict; refresh token 7d path-scoped to /api/v1/auth/refresh. Uses @nestjs/jwt + passport-jwt with custom cookie extractor; @fastify/cookie required since backend runs Fastify, not Express."}, {"id": "specs_005_jwt_auth_settings_research_csrf_double_submit", "label": "CSRF Double-Submit Cookie Pattern", "file_type": "rationale", "source_file": "specs/005-jwt-auth-settings/research.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Because tokens live in auto-sent HttpOnly cookies, CSRF is a real threat on mutations. Stateless double-submit: non-HttpOnly csrf_token cookie mirrored in X-CSRF-Token header, validated by a guard on POST/PATCH/DELETE. Rejected synchronizer tokens (needs DB state), SameSite alone (insufficient), csurf (deprecated)."}, {"id": "specs_005_jwt_auth_settings_research_bcrypt_hashing", "label": "bcrypt Password Hashing (cost 12)", "file_type": "rationale", "source_file": "specs/005-jwt-auth-settings/research.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Industry standard, GPU-attack resistant; cost 12 balances security and ~250ms hash time. Argon2 rejected for weaker Node.js ecosystem support."}, {"id": "specs_005_jwt_auth_settings_research_theme_persistence", "label": "Server-Stored Theme Preference", "file_type": "rationale", "source_file": "specs/005-jwt-auth-settings/research.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Theme stored on User model so preference persists across devices; applied via CSS class on <html> with TailwindCSS darkMode:'class'; persisted via PATCH /users/me."}, {"id": "specs_005_jwt_auth_settings_research_destructive_migration", "label": "Destructive Auth Migration", "file_type": "rationale", "source_file": "specs/005-jwt-auth-settings/research.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Per clarification, all pre-auth data is wiped (truncate decks/cards/card_states/review_logs/daily_counters) before adding User/Session tables and userId FK \u2014 avoids assigning orphaned records to users."}], "edges": [{"source": "specs_005_jwt_auth_settings_research_httponly_cookie_tokens", "target": "specs_005_jwt_auth_settings_spec_jwt_authentication", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "specs/005-jwt-auth-settings/research.md", "source_location": null, "weight": 1.0}, {"source": "specs_005_jwt_auth_settings_research_csrf_double_submit", "target": "specs_005_jwt_auth_settings_spec_jwt_authentication", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "specs/005-jwt-auth-settings/research.md", "source_location": null, "weight": 1.0}, {"source": "specs_005_jwt_auth_settings_research_csrf_double_submit", "target": "specs_005_jwt_auth_settings_research_httponly_cookie_tokens", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "specs/005-jwt-auth-settings/research.md", "source_location": null, "weight": 1.0}, {"source": "specs_005_jwt_auth_settings_research_bcrypt_hashing", "target": "specs_005_jwt_auth_settings_spec_jwt_authentication", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "specs/005-jwt-auth-settings/research.md", "source_location": null, "weight": 1.0}, {"source": "specs_005_jwt_auth_settings_research_theme_persistence", "target": "specs_005_jwt_auth_settings_spec_settings_profile_theme", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "specs/005-jwt-auth-settings/research.md", "source_location": null, "weight": 1.0}, {"source": "specs_005_jwt_auth_settings_research_destructive_migration", "target": "specs_005_jwt_auth_settings_data_model_user_scoping", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "specs/005-jwt-auth-settings/research.md", "source_location": null, "weight": 1.0}], "hyperedges": [{"id": "jwt_auth_token_lifecycle", "label": "JWT Auth Token Lifecycle (cookies, CSRF, sessions)", "nodes": ["specs_005_jwt_auth_settings_spec_jwt_authentication", "specs_005_jwt_auth_settings_research_httponly_cookie_tokens", "specs_005_jwt_auth_settings_research_csrf_double_submit", "specs_005_jwt_auth_settings_data_model_session"], "relation": "participate_in", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "specs/005-jwt-auth-settings/research.md"}]}